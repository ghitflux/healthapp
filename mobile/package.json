{
  "name": "abase-saude-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:go": "node ./node_modules/expo/bin/cli start --clear --go --lan",
    "start:go:tunnel": "node ./node_modules/expo/bin/cli start --clear --go --tunnel",
    "start:lan": "node ./node_modules/expo/bin/cli start --clear --dev-client --lan",
    "start:tunnel": "node ./node_modules/expo/bin/cli start --clear --dev-client --tunnel",
    "run:android": "node ./node_modules/expo/bin/cli run:android",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint app src babel.config.js eslint.config.js metro.config.js expo-env.d.ts nativewind-env.d.ts tailwind.config.ts --max-warnings=0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@kubb/plugin-client": "^4.27.2",
    "@react-native-firebase/app": "^23.4.1",
